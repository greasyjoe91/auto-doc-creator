{
  "name": "02-autodoc-flow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"npm run server:dev\" \"wait-on http://localhost:5173 && electron .\"",
    "server:dev": "cd server && npm run dev",
    "electron:build:win": "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.autodoc.flow",
    "productName": "AutoDoc Flow",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "server/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server"
      }
    ]
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "@types/dompurify": "^3.0.5",
    "docx": "^9.6.0",
    "dompurify": "^3.3.1",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.563.0",
    "mammoth": "1.6.0",
    "marked": "12.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "app-builder-bin": "^5.0.0-alpha.12",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
